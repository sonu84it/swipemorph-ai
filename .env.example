# Backend
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GCS_BUCKET_NAME=your-swipemorph-bucket
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
CORS_ALLOWED_ORIGINS=http://localhost:5173
SIGNED_URL_EXPIRATION_MINUTES=60
GCS_USE_PUBLIC_URLS=false

# Keep false for real Vertex AI generation. Set true only for local UI preview mode.
MOCK_VERTEX_IMAGES=false
BACKEND_PUBLIC_URL=http://127.0.0.1:8080
LOCAL_STORAGE_DIR=/tmp/swipemorph-ai

# Frontend
VITE_API_BASE_URL=http://localhost:8080
